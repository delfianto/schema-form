{
	"name": "schema-modal-form",
	"version": "1.0.0",
	"description": "Schema driven modal form plugin for Obsidian",
	"main": "src/main.js",
	"scripts": {
	"dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write ."
	},
	"keywords": [],
	"author": "",
	"license": "MIT",
	"devDependencies": {
		"@biomejs/biome": "^2.2.3",
		"@types/js-yaml": "^4.0.9",
		"@types/node": "^16.11.6",
		"builtin-modules": "3.3.0",
		"esbuild": "^0.25.9",
		"js-yaml": "^4.1.0",
		"obsidian": "latest",
		"tslib": "^2.8.1",
		"typescript": "^5.9.2"
	}
}
