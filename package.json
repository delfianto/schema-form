{
  "name": "schema-modal-form",
  "version": "1.0.0",
  "description": "Schema driven modal form plugin for Obsidian",
  "main": "src/main.ts",
  "scripts": {
    "build": "bun x tsc -noEmit -skipLibCheck && bun esbuild.config.mjs production",
    "check": "bun x biome check .",
    "check:fix": "bun x biome check --write .",
    "dev": "bun esbuild.config.mjs",
    "format": "bun x biome format --write .",
    "lint": "bun x biome lint .",
    "lint:fix": "bun x biome lint --write .",
    "test": "bun test",
    "version": "bun version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@biomejs/biome": "^2.2.3",
    "@types/bun": "latest",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.11.0",
    "builtin-modules": "3.3.0",
    "esbuild": "^0.28.0",
    "obsidian": "latest",
    "tslib": "^2.8.1",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "zod": "^4.2.1"
  }
}
