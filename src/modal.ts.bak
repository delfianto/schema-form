import { App, Modal, TFile, Setting, Notice } from "obsidian";
import { Schema, SchemaField, getErrorMessage } from "./types";

export class SchemaFormModal extends Modal {
	schema: Schema;
	formData: Record<string, any> = {};
	onSubmit: (data: Record<string, any> | null) => void;
	isSubmitted: boolean = false;
	fieldElements: Map<string, HTMLElement> = new Map(); // Track field elements for validation display
	enableDebugLogging: boolean;

	constructor(
		app: App,
		schema: Schema,
		enableDebugLogging: boolean,
		onSubmit: (data: Record<string, any> | null) => void,
	) {
		super(app);
		this.schema = schema;
		this.onSubmit = onSubmit;
		this.enableDebugLogging = enableDebugLogging;

		// Debug logging
		this.debugLog("Constructor called with schema:", schema);

		// Validate schema structure
		if (!schema) {
			throw new Error("Schema is null or undefined");
		}

		if (!schema.fields) {
			throw new Error("Schema must have a 'fields' property");
		}

		if (!Array.isArray(schema.fields)) {
			throw new Error("Schema 'fields' must be an array");
		}

		this.debugLog(
			"Schema validation passed, field count:",
			schema.fields.length,
		);
	}

	private debugLog(message: string, ...args: any[]) {
		if (this.enableDebugLogging) {
			console.log(`SchemaFormModal: ${message}`, ...args);
		}
	}

	onOpen() {
		this.debugLog("onOpen called");
		const { contentEl } = this;

		try {
			contentEl.createEl("h2", { text: "Form" });

			// Validate schema.fields exists and is an array before forEach
			if (!this.schema.fields || !Array.isArray(this.schema.fields)) {
				throw new Error(
					`Invalid schema structure: fields is ${typeof this.schema.fields}`,
				);
			}

			this.debugLog(
				"About to render",
				this.schema.fields.length,
				"fields",
			);

			// Render each field
			this.schema.fields.forEach((field, index) => {
				this.debugLog(`Rendering field ${index}:`, field);
				try {
					this.renderField(contentEl, field);
				} catch (fieldError) {
					const errorMsg = getErrorMessage(fieldError);
					console.error(
						`SchemaFormModal: Error rendering field ${index}:`,
						fieldError,
					);
					const errorEl = contentEl.createEl("div", {
						text: `Error rendering field "${field?.name || index}": ${errorMsg}`,
						cls: "schema-form-error", // Use CSS class instead of inline styles
					});
				}
			});

			// Validation summary area
			const summaryEl = contentEl.createEl("div", {
				cls: "schema-validation-summary",
			});
			this.fieldElements.set("validation-summary", summaryEl);

			// Submit button
			new Setting(contentEl)
				.addButton((btn) =>
					btn
						.setButtonText("Submit")
						.setCta()
						.onClick(() => this.handleSubmit()),
				)
				.addButton((btn) =>
					btn.setButtonText("Cancel").onClick(() => this.close()),
				);

			this.debugLog("Form rendered successfully");

			// Perform initial validation
			this.validateAllFields();
		} catch (error) {
			const errorMsg = getErrorMessage(error);
			console.error("SchemaFormModal: Error in onOpen:", error);
			contentEl.createEl("div", {
				text: `Error rendering form: ${errorMsg}`,
				cls: "schema-form-error", // Use CSS class instead of inline styles
			});

			// Still show cancel button
			new Setting(contentEl).addButton((btn) =>
				btn.setButtonText("Close").onClick(() => this.close()),
			);
		}
	}

	renderField(container: HTMLElement, field: SchemaField) {
		this.debugLog("renderField called with:", field);

		// Validate field structure
		if (!field) {
			throw new Error("Field is null or undefined");
		}

		if (!field.name) {
			throw new Error("Field must have a 'name' property");
		}

		if (!field.type) {
			throw new Error(
				`Field '${field.name}' must have a 'type' property`,
			);
		}

		// Create field container for validation styling
		const fieldContainer = container.createEl("div", {
			cls: `schema-field-container field-${field.name}`,
		});

		const setting = new Setting(fieldContainer)
			.setName((field.label || field.name) + (field.required ? " *" : ""))
			.setDesc(field.description || this.getFieldDescription(field));

		// Create validation message element
		const validationEl = fieldContainer.createEl("span", {
			cls: "schema-field-validation",
		});
		this.fieldElements.set(`validation-${field.name}`, validationEl);
		this.fieldElements.set(`container-${field.name}`, fieldContainer);

		// Set initial value from default, if available
		if (field.default !== undefined) {
			this.formData[field.name] = field.default;
		}

		const fieldType = field.type.toLowerCase();
		this.debugLog(
			`Rendering field type '${fieldType}' for field '${field.name}'`,
		);

		switch (fieldType) {
			case "text":
				setting.addText((text) => {
					text.setPlaceholder(
						field.required ? "Required" : "Optional",
					)
						.setValue(this.formData[field.name] || "")
						.onChange((value) => {
							this.formData[field.name] = value;
							this.validateField(field, value);
						});

					// Store input element for validation styling
					this.fieldElements.set(`input-${field.name}`, text.inputEl);
				});
				break;

			case "number":
				setting.addText((text) => {
					text.inputEl.type = "number";
					text.setPlaceholder(
						field.required ? "Required" : "Optional",
					).setValue(
						this.formData[field.name] !== undefined
							? String(this.formData[field.name])
							: "",
					);
					if (field.min !== undefined)
						text.inputEl.min = String(field.min);
					if (field.max !== undefined)
						text.inputEl.max = String(field.max);
					text.onChange((value) => {
						this.formData[field.name] = value
							? Number(value)
							: undefined;
						this.validateField(field, value);
					});

					// Store input element for validation styling
					this.fieldElements.set(`input-${field.name}`, text.inputEl);
				});
				break;

			case "select":
				setting.addDropdown((dropdown) => {
					if (field.options && Array.isArray(field.options)) {
						field.options.forEach((option) => {
							dropdown.addOption(String(option), String(option));
						});
						// Set initial value for dropdown
						dropdown.setValue(
							this.formData[field.name] || field.options[0],
						);
						// Ensure form data is set for dropdowns
						if (!this.formData[field.name]) {
							this.formData[field.name] = field.options[0];
						}
					} else {
						console.warn(
							`Field '${field.name}' has no valid options array`,
						);
						dropdown.addOption("No options", "No options");
					}
					dropdown.onChange((value) => {
						this.formData[field.name] = value;
						this.validateField(field, value);
					});

					// Store select element for validation styling
					this.fieldElements.set(
						`input-${field.name}`,
						dropdown.selectEl,
					);
				});
				break;

			default:
				console.warn(
					`Unknown field type: ${field.type} for field ${field.name}`,
				);
				setting.setDesc("Unknown field type: " + field.type);
		}

		this.debugLog(`Successfully rendered field '${field.name}'`);
	}

	validateField(field: SchemaField, value: any): string[] {
		const errors: string[] = [];
		const fieldName = field.name;

		// Required validation
		if (
			field.required &&
			(value === undefined || value === "" || value === null)
		) {
			errors.push(`${field.label || field.name} is required`);
		}

		// Skip other validations if field is empty and not required
		if (
			!field.required &&
			(value === undefined || value === "" || value === null)
		) {
			// Field is empty but not required - this is valid
			this.updateFieldValidation(fieldName, [], "Valid (optional)");
			return [];
		}

		// Type-specific validations
		switch (field.type.toLowerCase()) {
			case "text":
				// Regex validation
				if (field.regex && value) {
					try {
						const regex = new RegExp(field.regex);
						if (!regex.test(String(value))) {
							errors.push(
								`${field.label || field.name} does not match required pattern: ${field.regex}`,
							);
						}
					} catch (regexError) {
						errors.push(
							`${field.label || field.name} has invalid regex pattern`,
						);
					}
				}
				break;

			case "number":
				const numValue = Number(value);

				// Check if it's a valid number
				if (value !== "" && (isNaN(numValue) || !isFinite(numValue))) {
					errors.push(
						`${field.label || field.name} must be a valid number`,
					);
				} else if (value !== "" && isFinite(numValue)) {
					// Min validation
					if (field.min !== undefined && numValue < field.min) {
						errors.push(
							`${field.label || field.name} must be at least ${field.min}`,
						);
					}
					// Max validation
					if (field.max !== undefined && numValue > field.max) {
						errors.push(
							`${field.label || field.name} must be at most ${field.max}`,
						);
					}
				}
				break;

			case "select":
				// Validate that the selected value is in the options
				if (field.options && Array.isArray(field.options)) {
					if (!field.options.includes(value)) {
						errors.push(
							`${field.label || field.name} has an invalid selection`,
						);
					}
				}
				break;
		}

		// Update UI based on validation
		this.updateFieldValidation(
			fieldName,
			errors,
			errors.length === 0 ? "Valid" : null,
		);

		return errors;
	}

	updateFieldValidation(
		fieldName: string,
		errors: string[],
		successMessage?: string | null,
	) {
		const validationEl = this.fieldElements.get(`validation-${fieldName}`);
		const containerEl = this.fieldElements.get(`container-${fieldName}`);

		if (!validationEl || !containerEl) return;

		// Clear previous validation classes
		containerEl.classList.remove(
			"schema-field-valid",
			"schema-field-invalid",
		);

		if (errors.length > 0) {
			// Show errors
			containerEl.classList.add("schema-field-invalid");
			validationEl.className = "schema-field-error";
			validationEl.textContent = errors.join("; ");
		} else if (successMessage) {
			// Show success
			containerEl.classList.add("schema-field-valid");
			validationEl.className = "schema-field-valid";
			validationEl.textContent = successMessage;
		} else {
			// Clear validation message
			validationEl.textContent = "";
			validationEl.className = "schema-field-validation";
		}
	}

	validateAllFields(): { isValid: boolean; errors: string[] } {
		const allErrors: string[] = [];

		this.schema.fields.forEach((field) => {
			const value = this.formData[field.name];
			const fieldErrors = this.validateField(field, value);
			allErrors.push(...fieldErrors);
		});

		// Update validation summary
		const summaryEl = this.fieldElements.get("validation-summary");
		if (summaryEl) {
			summaryEl.innerHTML = "";
			if (allErrors.length > 0) {
				summaryEl.className = "schema-form-summary";
				summaryEl.createEl("strong", {
					text: "Please fix the following errors:",
				});
				const errorList = summaryEl.createEl("ul");
				allErrors.forEach((error) => {
					errorList.createEl("li", { text: error });
				});
			} else {
				summaryEl.className = "";
				const successDiv = summaryEl.createEl("div", {
					text: "✓ All fields are valid",
					cls: "schema-field-valid schema-validation-success", // Use CSS classes
				});
			}
		}

		return {
			isValid: allErrors.length === 0,
			errors: allErrors,
		};
	}

	getFieldDescription(field: SchemaField): string {
		const parts: string[] = [];
		if (field.regex) parts.push(`Pattern: ${field.regex}`);
		if (field.min !== undefined) parts.push(`Min: ${field.min}`);
		if (field.max !== undefined) parts.push(`Max: ${field.max}`);
		if (field.options && field.options.length > 0)
			parts.push(`Options: ${field.options.join(", ")}`);
		return parts.join(" | ");
	}

	handleSubmit() {
		this.debugLog("handleSubmit called");

		// Validate all fields
		const validation = this.validateAllFields();

		if (!validation.isValid) {
			this.debugLog("Validation errors:", validation.errors);
			new Notice(
				`Cannot submit: ${validation.errors.length} validation error(s). Please check the form.`,
			);

			// Scroll to first error field
			const firstErrorField = this.schema.fields.find((field) => {
				const fieldErrors = this.validateField(
					field,
					this.formData[field.name],
				);
				return fieldErrors.length > 0;
			});

			if (firstErrorField) {
				const containerEl = this.fieldElements.get(
					`container-${firstErrorField.name}`,
				);
				if (containerEl) {
					containerEl.scrollIntoView({
						behavior: "smooth",
						block: "center",
					});
				}
			}

			return;
		}

		// Final data cleanup for numbers
		const cleanedData = { ...this.formData };
		this.schema.fields.forEach((field) => {
			if (
				field.type.toLowerCase() === "number" &&
				cleanedData[field.name] !== undefined
			) {
				cleanedData[field.name] = Number(cleanedData[field.name]);
			}
		});

		// Call the provided onSubmit callback with the cleaned data
		this.debugLog("Submitting form data:", cleanedData);
		this.isSubmitted = true;
		this.onSubmit(cleanedData);
		this.close();
	}

	onClose() {
		this.debugLog("onClose called, isSubmitted:", this.isSubmitted);
		this.contentEl.empty();
		if (!this.isSubmitted) {
			this.debugLog("Form not submitted, returning empty object");
			new Notice("Dialog closed, returning empty object.");
			this.onSubmit({});
		}
	}
}
